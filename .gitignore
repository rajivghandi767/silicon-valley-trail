# ==========================================
# Unified Parity .gitignore
# ==========================================

# --- Environment Variables & Secrets ---
.env
.env.*
!.env.example
*.pem
*.POSTGRES_SECRETS
*.gcp-service-account.json

# --- Python & Django (Backend) ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
venv/
env/
.venv/
db.sqlite3
db.sqlite3-journal
staticfiles/
mediafiles/
backend/logs/

# --- Node & React (Frontend) ---
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
frontend/node_modules/
frontend/dist/
frontend/.eslintcache
frontend/coverage/

# --- Infrastructure as Code (GCP & Terraform) ---
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# --- OS & IDE Files ---
.DS_Store
.idea/
.vscode/
*.swp