# ---------------------------------------------------------
# Django Settings
# ---------------------------------------------------------
DJANGO_SECRET_KEY='django-insecure-local-testing-key-svt'
DJANGO_DEBUG='True'

# ---------------------------------------------------------
# Security & Routing
# ---------------------------------------------------------
# Configured for standard local development ports
ALLOWED_HOSTS='localhost,127.0.0.1,svt-backend'
CSRF_TRUSTED_ORIGINS='http://localhost:5173,http://127.0.0.1:5173'
CORS_ALLOWED_ORIGINS='http://localhost:5173,http://127.0.0.1:5173'

# ---------------------------------------------------------
# Database Configuration (PostgreSQL)
# ---------------------------------------------------------
POSTGRES_DB='svt_db'
POSTGRES_USER='svt_user'
POSTGRES_PASSWORD='svt_password'
POSTGRES_HOST='svt-local-db'
POSTGRES_PORT='5432'

# ---------------------------------------------------------
# Caching Configuration (Redis)
# ---------------------------------------------------------
REDIS_URL='redis://svt-local-redis:6379/0'

# ---------------------------------------------------------
# Frontend Configuration
# ---------------------------------------------------------
VITE_API_URL='http://localhost:8000'

# ---------------------------------------------------------
# External APIs (No Auth Required)
# ---------------------------------------------------------
OPEN_METEO_API_KEY=''
OPEN_METEO_MARINE_API_KEY=''